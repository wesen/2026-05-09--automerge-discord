{
  "name": "automerge-discord",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/chat-core packages/chat-acl packages/chat-client packages/chat-bot-worker packages/chat-server packages/chat-web && npm --workspace @autodisco/chat-web run build",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "tsc -b packages/chat-core packages/chat-acl packages/chat-client packages/chat-bot-worker packages/chat-server packages/chat-web --pretty false",
    "dev:server": "npm --workspace @autodisco/chat-server run dev",
    "dev:web": "npm --workspace @autodisco/chat-web run dev",
    "storybook": "npm --workspace @autodisco/chat-web run storybook"
  },
  "dependencies": {
    "@automerge/automerge": "latest",
    "@automerge/automerge-repo": "latest",
    "@automerge/automerge-repo-network-websocket": "latest",
    "@automerge/automerge-repo-storage-nodefs": "latest",
    "@reduxjs/toolkit": "^2.11.2",
    "express": "latest",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-redux": "^9.2.0",
    "ws": "latest"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.3.6",
    "@types/express": "latest",
    "@types/node": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "latest",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "msw": "^2.14.5",
    "msw-storybook-addon": "^2.0.7",
    "postcss": "^8.5.14",
    "storybook": "^10.3.6",
    "tailwindcss": "^3.4.19",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "^8.0.11",
    "vitest": "latest"
  },
  "msw": {
    "workerDirectory": [
      "packages/chat-web/public"
    ]
  }
}