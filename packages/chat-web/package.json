{
  "name": "@autodisco/chat-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port ${VITE_DEV_PORT:-5174} --strictPort",
    "build": "tsc -b tsconfig.json && vite build",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "storybook": "storybook dev -p 6006 --host 127.0.0.1",
    "build-storybook": "storybook build",
    "test:e2e": "playwright test -c playwright.config.ts"
  },
  "dependencies": {
    "@autodisco/chat-core": "0.1.0",
    "@automerge/automerge-repo": "latest",
    "@automerge/automerge-repo-network-websocket": "latest",
    "@automerge/automerge-repo-storage-indexeddb": "^2.5.5",
    "@reduxjs/toolkit": "^2.11.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {}
}
